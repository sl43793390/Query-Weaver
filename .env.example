# Query-Weaver environment configuration
# ---------------------------------------
# Copy this file to `.env` and fill in the values you want to override.
# At runtime, settings are read with this priority:
#   1. Process environment variable (wins over .env)
#   2. .env file (this file)
#   3. Local SQLite settings (set from inside the app)
#
# Leave a value blank to fall through to the next layer.

# --- LLM (OpenAI-compatible) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://www.dmxapi.cn

# --- LLM (local Ollama) ---
# When the provider is `ollama`, the manager will use OLLAMA_HOST or
# fall back to OPENAI_BASE_URL. The default is http://127.0.0.1:11434
# if neither is set.
# OLLAMA_HOST=http://127.0.0.1:11434
